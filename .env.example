# Root environment variables used by docker-compose.
# Copy to ".env" and change the credentials before running.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# Allowed CORS origins for the backend (comma separated). Use the deployed
# frontend URL in production, e.g. https://your-app.vercel.app
CORS_ORIGINS=*

LOW_STOCK_THRESHOLD=10

# URL the frontend uses to reach the backend (baked into the build).
VITE_API_URL=http://localhost:8000
